# PARISA MEMORY PORTAL — সব Secrets (এগুলো যেকোনো hosting-এ সেট করুন)
# Replit Secrets বা hosting provider-এর env panel-এ এগুলো যোগ করুন

# Firebase (Firebase Console → Project Settings → Your Apps)
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_DATABASE_URL=
FIREBASE_PROJECT_ID=
FIREBASE_STORAGE_BUCKET=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_APP_ID=
FIREBASE_MEASUREMENT_ID=

# Google OAuth (Google Cloud Console → APIs & Services → Credentials → OAuth 2.0)
GOOGLE_CLIENT_ID=
# রেফারেন্স: Google Console → Client ID → Client secret
# (API Server এ GOOGLE_CLIENT_SECRET হিসেবে সেট করুন)

# Google Drive (Google Cloud Console → APIs & Services → Credentials → API Key)
GOOGLE_DRIVE_API_KEY=
GOOGLE_DRIVE_PARENT_FOLDER_ID=

# Session Secret (যেকোনো random string, e.g.: openssl rand -base64 32)
SESSION_SECRET=

# Telegram (t.me/BotFather দিয়ে তৈরি করুন)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_CONTACT=

# Profile Logo URL (যেকোনো public image URL)
PROFILE_LOGO_URL=

# AI API Keys (একটি হলেও চলবে)
GROQ_API_KEYS=key1,key2,key3
GEMINI_API_KEYS=key1,key2
OPENROUTER_API_KEYS=key1

# IMPORTANT: Drive Redirect URI
# Google Console → OAuth Client → Authorized Redirect URIs-এ যোগ করুন:
# https://<আপনার-ডোমেইন>/api/oauth/callback
