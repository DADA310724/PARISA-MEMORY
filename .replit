modules = ["nodejs-20", "web", "bash"]
[agent]
expertMode = true
stack = "BEST_EFFORT_FALLBACK"

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 8080
externalPort = 8080

[[ports]]
localPort = 8081
externalPort = 8081

[[ports]]
localPort = 23236
externalPort = 80

[nix]
channel = "stable-25_05"

[deployment]
deploymentTarget = "autoscale"
run = ["bash", "-c", "PORT=8080 node --enable-source-maps artifacts/api-server/dist/index.js"]
build = ["bash", "-c", "pnpm install && pnpm --filter @workspace/parisa-portal run build && pnpm --filter @workspace/api-server run build"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "PORT=5000 pnpm --filter @workspace/parisa-portal run dev"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow]]
name = "PORT=5000 pnpm --filter @workspace/parisa-portal run dev"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "PORT=5000 pnpm --filter @workspace/parisa-portal run dev"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow]]
name = "artifacts/parisa-portal: web"
author = "agent"
mode = "sequential"

[workflows.workflow.metadata]
outputType = "webview"
artifactId = "parisa-portal"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm --filter @workspace/parisa-portal run dev"
cwd = "./artifacts/parisa-portal"
waitForPort = 23236
router = "path"

[workflows.workflow.tasks.env]
PORT = "23236"
BASE_PATH = "/"

[[workflows.workflow]]
name = "artifacts/mockup-sandbox: Component Preview Server"
author = "agent"
mode = "sequential"

[workflows.workflow.metadata]
outputType = "webview"
artifactId = "XegfDyZt7HqfW2Bb8Ghoy"
isCanvasWorkflow = true

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm --filter @workspace/mockup-sandbox run dev"
cwd = "./artifacts/mockup-sandbox"
waitForPort = 8081

[workflows.workflow.tasks.env]
PORT = "8081"
BASE_PATH = "/__mockup"
